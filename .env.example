# Stripe — remplacez par vos clés réelles avant la mise en production
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Authentification de démonstration (facultatif en dev — des valeurs par
# défaut existent ; définissez-les impérativement en production)
AUTH_SECRET=
SEED_ADMIN_PASSWORD=
SEED_DEMO_PASSWORD=

# Tests E2E Playwright (facultatif — mêmes valeurs par défaut que l'app)
E2E_BASE_URL=
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=

# Audio IA (ElevenLabs) — active la voix off et la musique dans la vidéo.
# Sans clé, l'option audio n'apparaît pas et la vidéo reste muette.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Script IA (Claude / Anthropic) — génère storyboard + voix off à partir du
# brief. Sans clé, le tunnel retombe sur la génération par gabarit.
ANTHROPIC_API_KEY=

# Clip d'ambiance IA (Higgsfield) — génère un clip thématique lié à l'univers
# du produit. Renseigne SOIT HF_CREDENTIALS ("KEY_ID:KEY_SECRET"), SOIT le
# couple HF_API_KEY + HF_API_SECRET. Sans clés, l'option n'apparaît pas.
HF_CREDENTIALS=
HF_API_KEY=
HF_API_SECRET=

# Price IDs — mode "à la vidéo"
STRIPE_PRICE_60=
STRIPE_PRICE_90=
STRIPE_PRICE_120=

# Price IDs — abonnements mensuels
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_AGENCY=
