# Stripe — remplacez par vos clés réelles avant la mise en production
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Authentification de démonstration (facultatif en dev — des valeurs par
# défaut existent ; définissez-les impérativement en production)
AUTH_SECRET=
SEED_ADMIN_PASSWORD=
SEED_DEMO_PASSWORD=

# Tests E2E Playwright (facultatif — mêmes valeurs par défaut que l'app)
E2E_BASE_URL=
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=

# Price IDs — mode "à la vidéo"
STRIPE_PRICE_60=
STRIPE_PRICE_90=
STRIPE_PRICE_120=

# Price IDs — abonnements mensuels
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_AGENCY=
